{
  "buildCommand": "exit 0",
  "outputDirectory": ".",
  "framework": null,
  "public": true,
  "headers": [
    {
      "source": "/audio/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000"
        },
        {
          "key": "Content-Type",
          "value": "audio/mpeg"
        }
      ]
    }
  ]
}
